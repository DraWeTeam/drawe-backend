# Server
SERVER_PORT=8080

# Database
DB_PORT=3306
DB_USERNAME=user
DB_PASSWORD=change-me-user
MYSQL_ROOT_PASSWORD=change-me-root

# Redis (Valkey)
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis

# JPA
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
LOG_LEVEL_SQL=debug

# JWT
JWT_SECRET=please-replace-with-long-random-string-at-least-32-chars
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# CORS (로컬: localhost:5173, AWS: 가비아 도메인)
APP_CORS_ALLOWED_ORIGINS=https://drawe.xyz,https://www.drawe.xyz,http://localhost:5173,https://drawe-frontend.pages.dev

# Domain — Caddy가 이 도메인으로 인증서 발급
DOMAIN_NAME=api.drawe.xyz

# LLM API Keys
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GROK_API_KEY=YOUR_GROK_API_KEY
CLAUDE_API_KEY=YOUR_CLAUDE_API_KEY

# Optional overrides
# LLM_DEFAULT_PROVIDER=gemini

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
APP_OAUTH2_REDIRECT_URI=https://drawe.xyz/oauth/callback
#APP_OAUTH2_REDIRECT_URI=http://localhost:5173/oauth/callback